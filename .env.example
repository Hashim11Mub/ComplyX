# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=sama_regulations

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── Corpus ────────────────────────────────────────────────────────────────────
CORPUS_VERSION=2026-07

# ── Frontend → Backend proxy ──────────────────────────────────────────────────
# Set this when running the real backend. Leave empty to use mock.
BACKEND_URL=http://localhost:8000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ComplyX

# ── LangSmith tracing (optional but recommended during development) ───────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=complyx-amad
